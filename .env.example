HOME_ASSISTANT_BASE_URL=http://192.168.150.100:8123
HOME_ASSISTANT_TOKEN=replace_with_your_home_assistant_long_lived_access_token
HA_TOKEN=replace_with_your_home_assistant_long_lived_access_token
HOME_ASSISTANT_TIMEOUT_MS=15000
LIGHTS_CONFIG_PATH=./config/lights.json

# PostgreSQL audit log storage
DATABASE_URL=postgresql://username:password@localhost:5432/home_assistant_mcp
# Or use POSTGRES_URL if your deployment already provides it
# POSTGRES_URL=postgresql://username:password@localhost:5432/home_assistant_mcp

# Optional: legacy JSON file used only for one-time migration on startup
AUDIT_JSON_PATH=./packages/mcp-server/data/audit-log.json

LOG_LEVEL=info
ADMIN_WEB_PORT=4000
VITE_ADMIN_API_BASE_URL=http://127.0.0.1:4000
